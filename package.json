{
    "name": "holy-js-app",
    "private": true,
    "scripts": {
        "start": "tramvai start holy-js-app",
        "build": "tramvai build holy-js-app",
        "preview": "tramvai start-prod holy-js-app",
        "analyze": "tramvai holy-js-app --analyze=statoscope",
        "lint": "eslint --ext .ts,.tsx --ignore-path .gitignore .",
        "test": "jest --passWithNoTests",
        "test:watch": "jest --watch",
        "test:integration": "playwright test"
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged"
        }
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": [
            "eslint --fix"
        ]
    },
    "packageManager": "yarn@4.13.0",
    "dependencies": {
        "@tramvai/core": "^6.79.33",
        "@tramvai/module-child-app": "^6.79.33",
        "@tramvai/module-common": "^6.79.33",
        "@tramvai/module-error-interceptor": "^6.79.33",
        "@tramvai/module-render": "^6.79.33",
        "@tramvai/module-router": "^6.79.33",
        "@tramvai/module-seo": "^6.79.33",
        "@tramvai/module-server": "^6.79.33",
        "@tramvai/react": "^6.79.33",
        "@tramvai/state": "^6.79.33",
        "@tramvai/tokens-render": "^6.79.33",
        "@tramvai/tokens-router": "^6.79.33",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "tslib": "^2.0.3"
    },
    "devDependencies": {
        "@jest/types": "^29.6.3",
        "@playwright/test": "^1.58.2",
        "@testing-library/react": "^16.3.2",
        "@tinkoff/eslint-config": "^5.2.0",
        "@tinkoff/eslint-config-react": "^5.2.0",
        "@tinkoff/eslint-plugin-tramvai": "^0.10.9",
        "@tramvai/cli": "^6.79.33",
        "@tramvai/prettier-config": "^1.0.3",
        "@tramvai/swc-integration": "^6.79.33",
        "@tramvai/test-react": "^6.79.33",
        "@tramvai/test-unit": "^6.79.33",
        "@tramvai/test-unit-jest": "^6.79.33",
        "@types/react": "^19.2.14",
        "husky": "^4",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "lint-staged": "^16.4.0",
        "postcss-custom-media": "^12.0.1",
        "postcss-custom-properties": "^15.0.1",
        "postcss-modules-values-replace": "^4.2.2",
        "postcss-nested": "^7.0.2",
        "source-map": "^0.7.6",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "webpack-sources": "^3.3.4"
    }
}
